{
  "name": "timescope",
  "productName": "TimeScope",
  "version": "0.4.2",
  "description": "Privacy-first automatic time tracking for Windows. All data stays local.",
  "main": "dist/main/index.js",
  "author": "TimeScope",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "build": "npm run icons && npm run typecheck && node scripts/build-main.mjs && vite build",
    "icons": "node scripts/generate-icons.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "start": "npm run build && electron .",
    "smoke": "node scripts/smoke.mjs",
    "dist": "npm run build && electron-builder --win"
  },
  "dependencies": {
    "koffi": "^2.9.0",
    "node-sqlite3-wasm": "^0.8.35"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^38.0.0",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.25.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "recharts": "^2.15.0",
    "typescript": "^5.8.0",
    "vite": "^6.3.0",
    "vitest": "^3.1.0"
  }
}
